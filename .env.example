# swiftllm configuration
# Copy this file to .env and fill in your API keys.
# Place the .env file in the same directory as the swiftllm executable.

# ── Server ──
PORT=8080

# ── Authentication ──
# Comma-separated API keys that clients must provide (leave empty to disable auth)
AUTH_API_KEYS=your-proxy-api-key

# ── Routing ──
DEFAULT_PROVIDER=openai

# ── Cache ──
CACHE_ENABLED=true
CACHE_MAX_SIZE=1000
CACHE_TTL_SECONDS=300

# ── Rate Limiting ──
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Per-provider rate limit overrides
RATE_LIMIT_OPENAI_MAX_REQUESTS=200
RATE_LIMIT_OPENAI_WINDOW_SECONDS=60
RATE_LIMIT_ANTHROPIC_MAX_REQUESTS=50
RATE_LIMIT_ANTHROPIC_WINDOW_SECONDS=60

# ── Providers ──
# Configure each provider by setting its API key and models.
# Only providers with an API key (or base_url for Ollama) will be enabled.

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODELS=gpt-4o,gpt-4o-mini,gpt-4.1,gpt-4.1-mini,gpt-4.1-nano,o3,o3-mini,o4-mini
OPENAI_PRIORITY=1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-6,claude-haiku-4-5-20251001
ANTHROPIC_PRIORITY=2

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODELS=gemini-2.0-flash,gemini-2.0-pro,gemini-1.5-pro,gemini-1.5-flash
GEMINI_PRIORITY=3

# Mistral
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODELS=mistral-large-latest,mistral-small-latest,codestral-latest,ministral-8b-latest,pixtral-large-latest
MISTRAL_PRIORITY=4

# Ollama (local — no API key needed, just set base_url and/or models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=llama3:latest,mistral:latest,codellama:latest
OLLAMA_PRIORITY=10
